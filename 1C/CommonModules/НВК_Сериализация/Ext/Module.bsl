// Возвращает строку в формате JSON, содержащую сериализованные данные
//
// Параметры:
//   Данные - Произвольный - данные для сериализации в JSON
//
// Возвращаемое значение:
//   Строка - строка в формате JSON
Функция ДанныеВСтрокуJSON(Знач Данные) Экспорт
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    Возврат ЗаписьJSON.Закрыть();
КонецФункции

// Десериализует строку в формате JSON в данные 1С
//
// Параметры:
//   СтрокаJSON - Строка - строка в формате JSON
//
// Возвращаемое значение:
//   Произвольный - десериализованные данные (Соответствие, Массив, Строка или другие типы)
//   - Неопределено - если строка пуста или при ошибке десериализации
Функция СтрокуJSONВДанные(Знач СтрокаJSON) Экспорт
    
    Если Не ЗначениеЗаполнено(СтрокаJSON) Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    ЧтениеJSON = Новый ЧтениеJSON;
    Попытка
        ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
        Данные = ПрочитатьJSON(ЧтениеJSON);
        ЧтениеJSON.Закрыть();
        Возврат Данные;
    Исключение
        ЗаписьЖурналаРегистрации("НВК_Сериализация", УровеньЖурналаРегистрации.Ошибка,,, 
            "Ошибка десериализации JSON: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции
