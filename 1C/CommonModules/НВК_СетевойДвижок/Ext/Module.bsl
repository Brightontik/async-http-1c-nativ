// Проверяет и подготавливает пакет задач к выполнению: валидирует обязательные параметры
// и заполняет значения по умолчанию для отсутствующих параметров.
//
// Параметры:
//   МассивЗадач - Массив из Структура - массив задач для обработки
//     * task_id - Строка - обязательный параметр, идентификатор задачи
//     * url - Строка - обязательный параметр, адрес для выполнения запроса
//     * service_name - Строка - имя сервиса, заполняется значением "ОбщийСервис" по умолчанию
//     * method - Строка - метод HTTP-запроса, заполняется пустой строкой по умолчанию
//     * headers - Структура - заголовки запроса, заполняется пустой структурой по умолчанию
//     * payload - Строка - тело запроса, заполняется пустой строкой по умолчанию
//
// Возвращаемое значение:
//   Булево - Истина, если пакет задач успешно валидирован и подготовлен; Ложь при обнаружении критических ошибок
Функция ВалидироватьИПодготовитьПакет(МассивЗадач)
	ИмяСобытияЖР = "НВК_ВалидацияПакетa";
	ОшибкиОбнаружены = Ложь;
	
	Для Каждого Задача ИЗ МассивЗадач Цикл
		Если НЕ Задача.Свойство("task_id") ИЛИ НЕ ЗначениеЗаполнено(Задача.task_id) Тогда
			ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка,,, 
				"Критическая ошибка: В задаче отсутствует или не заполнен обязательный параметр 'task_id'!");
			ОшибкиОбнаружены = Истина;
			Прервать;
		КонецЕсли;
		Если НЕ Задача.Свойство("url") ИЛИ НЕ ЗначениеЗаполнено(Задача.url) Тогда
			ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка,,, 
				"Критическая ошибка для задачи '" + Задача.task_id + "': отсутствует или не заполнен параметр 'url'!");
			ОшибкиОбнаружены = Истина;
			Прервать;	
		КонецЕсли;
		Если НЕ Задача.Свойство("service_name") ИЛИ НЕ ЗначениеЗаполнено(Задача.service_name) Тогда
			Задача.Вставить("service_name", "ОбщийСервис");	
		КонецЕсли;
		Если НЕ Задача.Свойство("method") Тогда
			Задача.Вставить("method", "");	
		КонецЕсли;
		Если НЕ Задача.Свойство("headers") ИЛИ Задача.headers = Неопределено Тогда
			Задача.Вставить("headers", Новый Структура);
		КонецЕсли;
		Если НЕ Задача.Свойство("payload") Тогда
			Задача.Вставить("payload", "");
		КонецЕсли;
	КонецЦикла;
	
	Возврат НЕ ОшибкиОбнаружены;
КонецФункции

// Добавляет пакет задач во внешнюю компоненту сетевого движка.
//
// Параметры:
//   МассивЗадач - Массив - массив задач для добавления
//   Проверка - Булево - выполнять ли валидацию и подготовку пакета
//
// Возвращаемое значение:
//   Булево - Истина, если пакет задач успешно добавлен, Ложь в противном случае
Функция ДобавитьПакетЗадач(Знач МассивЗадач, Знач Проверка = Истина) Экспорт
	ИмяСобытияЖР = "НВК_ОтправкаПакета";
	Если НЕ ЗначениеЗаполнено(МассивЗадач) ИЛИ МассивЗадач.Количество()=0 Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	Если Проверка И НЕ ВалидироватьИПодготовитьПакет(МассивЗадач) Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	ВК = НВК_СетевойДвижокПовтИсп.ПолучитьИнициализированнуюКомпоненту();
	Если ВК = Неопределено Тогда
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Предупреждение,,, 
			"Добавление пакета задач отменено: Компонента не загружена.");
		Возврат Ложь;
	КонецЕсли;
	
	ПакетЗадач = Новый Структура("tasks", МассивЗадач);
	СтрокаЗадачJSON = НВК_Сериализация.ДанныеВСтрокуJSON(ПакетЗадач);
	
	Попытка
		УспешноДобавлено = ВК.ДобавитьЗадачу(СтрокаЗадачJSON);	
	Исключение
		УспешноДобавлено = Ложь;
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка,,, 
			"Исключение при вызове ВК.ДобавитьЗадачу(): " + ОписаниеОшибки());	
	КонецПопытки;
	
	Возврат УспешноДобавлено;
КонецФункции

// Подтверждает получение задач через внешнюю компоненту сетевого движка.
//
// Параметры:
//   МассивИдентификаторов - Массив из Строка, УникальныйИдентификатор - идентификаторы задач для подтверждения получения
Процедура ПодтвердитьПолучениеЗадач(Знач МассивИдентификаторов) Экспорт
	ИмяСобытияЖР = "НВК_Подтверждение";
	
	Если Не ЗначениеЗаполнено(МассивИдентификаторов) ИЛИ МассивИдентификаторов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВК = НВК_СетевойДвижокПовтИсп.ПолучитьИнициализированнуюКомпоненту();
	Если ВК = Неопределено Тогда
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Предупреждение,,, 
			"ACK отменен: Компонента не загружена.");
		Возврат;
	КонецЕсли;
	
	СтрокаACKJSON = НВК_Сериализация.ДанныеВСтрокуJSON(МассивИдентификаторов);
	
	Попытка
		ВК.ПодтвердитьПолучение(СтрокаACKJSON);	
	Исключение
			ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка,,, 
			"Исключение при вызове ВК.ПодтвердитьПолучение(): " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

// Возвращает результаты запросов из внешней компоненты для указанного сервиса.
//
// Параметры:
//   ИмяСервиса - Строка - имя сервиса для получения результатов. Если не указано или пустая строка - для всех сервисов
//   Лимит - Число - максимальное количество результатов для получения
//
// Возвращаемое значение:
//   Массив - массив результатов запросов
//   - ПустойМассив - если компонента не загружена, произошла ошибка или результаты отсутствуют
Функция ЗабратьРезультатыЗапросов(Знач ИмяСервиса = "", Знач Лимит = 1000) Экспорт
	ИмяСобытияЖР = "НВК_ЧтениеРезультатов";
	
	ВК = НВК_СетевойДвижокПовтИсп.ПолучитьИнициализированнуюКомпоненту();
	Если ВК = Неопределено Тогда
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Предупреждение,,, 
			"Результаты пусты: Компонента не загружена.");
		Возврат Новый Массив;
	КонецЕсли;
	
	Попытка
		СтрокаРезультатовJSON = ВК.ЗабратьРезультаты(СокрЛП(ИмяСервиса), Лимит);	
	Исключение
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка,,, 
			"Исключение при вызове ВК.ЗабратьРезультаты(): " + ОписаниеОшибки());
		Возврат Новый Массив;
	КонецПопытки;
	
	МассивРезультатов = НВК_Сериализация.СтрокуJSONВДанные(СтрокаРезультатовJSON);
	
	Если МассивРезультатов = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Возврат МассивРезультатов;
КонецФункции

// Забирает результаты запросов для указанного сервиса и автоматически подтверждает их получение
//
// Параметры:
//   ИмяСервиса - Строка - имя сервиса, из которого требуется получить результаты
//   Лимит - Число - максимальное количество результатов для получения
//
// Возвращаемое значение:
//   Массив из Структура - результаты запросов, каждый результат содержит поле task_id
Функция ЗабратьРезультатыСАвтоПодтверждением(Знач ИмяСервиса = "", Знач Лимит = 1000) Экспорт
	МассивРезультатов = ЗабратьРезультатыЗапросов(ИмяСервиса, Лимит);
	
	Если МассивРезультатов.Количество() = 0 Тогда
		Возврат МассивРезультатов;
	КонецЕсли;
	
	МассивIDДляУдаления = Новый Массив;
	Для Каждого Результат из МассивРезультатов Цикл
		МассивIDДляУдаления.Добавить(Результат.task_id);
	КонецЦикла;
	
	ПодтвердитьПолучениеЗадач(МассивIDДляУдаления);
	Возврат МассивРезультатов;
КонецФункции