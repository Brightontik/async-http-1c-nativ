

// Выполняет стресс-тест обмена с 10 разными сайтами через Rust-конвейер.
// Выводит результаты выполнения в текстовое поле на форме.
&НаСервере
Процедура ВыполнитьТестВКНаСервере()
	
	РезультатОбмена.Очистить();
	РезультатОбмена.ДобавитьСтроку("=== ЗАПУСК СТРЕСС-ТЕСТА: ОБМЕН С 10 РАЗНЫМИ САЙТАМИ ===");
	
	// 1. Формируем массив из 10 абсолютно РАЗНЫХ сетевых задач
	МассивЗадач = Новый Массив;
	
	// Задача 1: Яндекс
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_001", "СтрессТест1С", "https://ya.ru", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 2: Гугл
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_002", "СтрессТест1С", "https://google.com", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 3: Википедия
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_003", "СтрессТест1С", "https://wikipedia.org", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 4: Mail.ru
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_004", "СтрессТест1С", "https://mail.ru", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 5: GitHub
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_005", "СтрессТест1С", "https://github.com", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 6: Хабр
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_006", "СтрессТест1С", "https://habr.com", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 7: Официальный сайт Rust
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_007", "СтрессТест1С", "https://rust-lang.org", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 8: Лента.ру
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_008", "СтрессТест1С", "https://lenta.ru", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 9: РБК
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_009", "СтрессТест1С", "https://rbc.ru", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	// Задача 10: Заведомо мертвый домен для проверки изоляции аварийных сбоев
	Задача = Новый Структура("task_id, service_name, url, method, headers, payload", 
		"stress_task_010", "СтрессТест1С", "https://this-domain-dead-12345.org", "GET", Новый Структура, "");
	МассивЗадач.Добавить(Задача);
	
	РезультатОбмена.ДобавитьСтроку("Отправляем пакет из 10 параллельных задач в Rust-конвейер...");
	
	ВК = НВК_СетевойДвижокПовтИсп.ПолучитьИнициализированнуюКомпоненту();
	УспехНастройки = НВК_НастройкиСетевогоДвижка.ИнициализироватьДвижокВRust(ВК);
	Если Не УспехНастройки Тогда
		РезультатОбмена.ДобавитьСтроку("❌ Критическая ошибка: Не удалось отправить настройку ВК. См. Журнал Регистрации.");
		Возврат;
	КонецЕсли;
	УспехОтправки = НВК_СетевойДвижок.ДобавитьПакетЗадач(МассивЗадач, Истина);
	
	Если Не УспехОтправки Тогда
		РезультатОбмена.ДобавитьСтроку("❌ Критическая ошибка: Не удалось отправить пакет задач в конвейер. См. Журнал Регистрации.");
		Возврат;
	КонецЕсли;
	
	МассивРезультатов = Новый Массив;
	ПопытокОпроса = 0;
	
	РезультатОбмена.ДобавитьСтроку("ВК мгновенно приняла очередь. 1С свободна. Начинаем опрашивать кэш ответов...");
	
	Пока ПопытокОпроса < 20 Цикл
		
		НачалоМикроПаузы = ТекущаяДата();
		Пока ТекущаяДата() - НачалоМикроПаузы < 0.5 Цикл
			ВременнаяПеременная = Sin(1) * Cos(1); 
		КонецЦикла;
		
		ТекущийСрез = НВК_СетевойДвижок.ЗабратьРезультатыЗапросов("СтрессТест1С", 100);
		
		Если ТекущийСрез.Количество() = 10 Тогда
			МассивРезультатов = ТекущийСрез;
			РезультатОбмена.ДобавитьСтроку(" Все 10 асинхронных задач успешно дождались выполнения на секунде: " + Строка(ПопытокОпроса * 0.5));
			Прервать;
		КонецЕсли;
		
		МассивРезультатов = ТекущийСрез;
		ПопытокОпроса = ПопытокОпроса + 1;
	КонецЦикла;
	
	РезультатОбмена.ДобавитьСтроку("=================================================");
	РезультатОбмена.ДобавитьСтроку(" ИТОГОВЫЙ ОТЧЕТ ОБМЕНА (Получено строк: " + Строка(МассивРезультатов.Количество()) + "):");
	РезультатОбмена.ДобавитьСтроку("=================================================");
	
	МассивIDДляУдаления = Новый Массив;
	
	Для Каждого ТекРезультат Из МассивРезультатов Цикл
		
		ИдЗадачи   = ТекРезультат.task_id;
		КодСтатуса = ТекРезультат.status_code;
		ОшибкаСети = ТекРезультат.error;
		ТелоОтвета = ТекРезультат.response_body;
		
		РезультатОбмена.ДобавитьСтроку("");
		РезультатОбмена.ДобавитьСтроку(" ИДЕНТИФИКАТОР ЗАДАЧИ: " + ИдЗадачи);
		
		Если ЗначениеЗаполнено(ОшибкаСети) Тогда
			РезультатОбмена.ДобавитьСтроку("   ❌ ОШИБКА СВЯЗИ: " + ОшибкаСети);
		Иначе
			РезультатОбмена.ДобавитьСтроку("   ✅ HTTP СТАТУС: " + Строка(КодСтатуса) + " | Длина ответа: " + Строка(СтрДлина(ТелоОтвета)) + " симв.");
			
			Если ЗначениеЗаполнено(ТелоОтвета) Тогда
				КусокРазметки = Лев(СокрЛП(ТелоОтвета), 250);
				КусокРазметки = СтрЗаменить(КусокРазметки, Символы.ПС, " ");
				КусокРазметки = СтрЗаменить(КусокРазметки, Символы.ВК, " ");
				
				РезультатОбмена.ДобавитьСтроку("    ДАМП НАЧАЛА СТРАНИЦЫ:");
				РезультатОбмена.ДобавитьСтроку("   \" + КусокРазметки + "... [вырезано]\");
			Иначе
				РезультатОбмена.ДобавитьСтроку("    Тело ответа пустое (например, сервер вернул редирект или пустой заголовок)");
			КонецЕсли;
		КонецЕсли;
		
		РезультатОбмена.ДобавитьСтроку("   -------------------------------------------------");
		МассивIDДляУдаления.Добавить(ИдЗадачи);
	КонецЦикла;
	
	РезультатОбмена.ДобавитьСтроку("=================================================");
	
	Если МассивIDДляУдаления.Количество() > 0 Тогда
		НВК_СетевойДвижок.ПодтвердитьПолучениеЗадач(МассивIDДляУдаления);
		РезультатОбмена.ДобавитьСтроку(" ОЗУ RUST УСПЕШНО ОЧИЩЕНО ДЛЯ ВСЕХ ОБРАБОТАННЫХ СТРОК.");
	КонецЕсли;
	
	РезультатОбмена.ДобавитьСтроку("=== СТРЕСС-ТЕСТ ЗАВЕРШЕН ===");

КонецПроцедуры



&НаКлиенте
Процедура Тест(Команда)
	ВыполнитьТестВКНаСервере();
КонецПроцедуры
